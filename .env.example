# ──────────────────────────────────────────────
# PIEE — Environment Configuration
# ──────────────────────────────────────────────

# Deployment mode: "local" or "cloud"
DEPLOYMENT_MODE=local

# Database
DATABASE_URL=file:./dev.db

# Security
JWT_SECRET=abc123
ENCRYPTION_KEY=change-me-generate-with-python-c-from-cryptography-fernet-import-Fernet-print-Fernet-generate-key

# Server
HOST=0.0.0.0
PORT=8000

# ──────────────────────────────────────────────
# Feature Flags (override defaults)
# ──────────────────────────────────────────────
BILLING_ENABLED=false
USAGE_LIMITS_ENABLED=false
PREMIUM_MODELS_ENABLED=false
ADMIN_DASHBOARD_ENABLED=false

# ──────────────────────────────────────────────
# Provider API Keys (encrypted at rest in DB,
# but can bootstrap via env for first run)
# ──────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_INFERENCE_URL=http://localhost:11434
